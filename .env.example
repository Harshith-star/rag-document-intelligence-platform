# ── REQUIRED — copy this file to .env and fill in every value ─────────────
# docker compose will refuse to start if SECRET_KEY or POSTGRES_PASSWORD is empty.

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# Strong password for PostgreSQL
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── OPTIONAL — sensible defaults shown ───────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=models/text-embedding-004
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
LOG_LEVEL=INFO
